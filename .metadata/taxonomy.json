{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "repository": "prompt-x-lab",
  "version": "0.1.0",
  "updated": "2026-04-11",
  "layers": [
    {
      "id": "00_foundation",
      "name": "Foundation",
      "purpose": "Primitives every module inherits: identity, constraints, output shape.",
      "depends_on": []
    },
    {
      "id": "01_cognition",
      "name": "Cognition",
      "purpose": "Thinking architectures — executive engines, multi-agent triads, reasoning scaffolds.",
      "depends_on": ["00_foundation"]
    },
    {
      "id": "02_engineering",
      "name": "Engineering",
      "purpose": "Code synthesis, review, refactor, test generation.",
      "depends_on": ["00_foundation", "01_cognition"]
    },
    {
      "id": "03_personas",
      "name": "Personas",
      "purpose": "Specialized interactive agents for domain tasks.",
      "depends_on": ["00_foundation"]
    },
    {
      "id": "04_validation",
      "name": "Validation",
      "purpose": "Output-gate modules: hallucination, fallacy, schema enforcement.",
      "depends_on": ["00_foundation"]
    },
    {
      "id": "05_orchestration",
      "name": "Orchestration",
      "purpose": "Production-grade, long-form system prompts adapted from the Advanced Orchestration v1 bundle: execution protocols, PR agents, flagship frameworks, crypto/trading systems, research methodologies.",
      "depends_on": ["00_foundation", "01_cognition", "04_validation"],
      "sublayers": [
        {"id": "protocols",  "label": "Execution Protocols",       "modules": 6},
        {"id": "agents",     "label": "PR Agents",                 "modules": 9},
        {"id": "frameworks", "label": "Flagship Frameworks",       "modules": 5},
        {"id": "crypto",     "label": "Crypto & Trading",          "modules": 3},
        {"id": "research",   "label": "Methodology & Research",    "modules": 3}
      ]
    },
    {
      "id": "06_eca_engine",
      "name": "ECA Cognitive Engine",
      "purpose": "Full production subsystem: ECA v1.1.0 integrated as content (34 files) + typed Python port (src/pxl/eca/, mypy --strict clean) + reproduction tests that enforce the 77-iteration calibration contract (router 99.44% / adversarial 100% / scorer 90.62% balanced, FP=0).",
      "depends_on": ["00_foundation", "01_cognition", "04_validation"],
      "version": "1.1.0",
      "selected_iteration": 27,
      "modes": [
        "deep_analysis",
        "executive_decision_brief",
        "system_architecture_blueprint",
        "human_performance_protocol",
        "cognitive_error_audit",
        "implementation_roadmap"
      ],
      "sublayers": [
        {"id": "core",       "label": "Core (prompt, proof tiers, config, templates, contract)", "modules": 6},
        {"id": "runtime",    "label": "Runtime (policy, fallback, router spec, context budgeting)", "modules": 4},
        {"id": "benchmarks", "label": "Benchmarks (metrics, rubric, live protocol)", "modules": 3},
        {"id": "security",   "label": "Security (model, guardrails, provenance)", "modules": 3},
        {"id": "schemas",    "label": "Schemas (request + response envelopes)", "modules": 2},
        {"id": "legal",      "label": "Legal (EULA template)", "modules": 1},
        {"id": "docs",       "label": "Docs (architecture, calibration, operations, release notes)", "modules": 15}
      ],
      "holdout_results": {
        "router_synthetic": {"accuracy": 1.0, "macro_f1": 1.0},
        "router_adversarial": {"accuracy": 1.0, "macro_f1": 1.0},
        "scorer": {"balanced_accuracy": 0.9167, "f1": 0.9091, "tp": 15, "tn": 18, "fp": 0, "fn": 3}
      },
      "full_corpus_reproduction": {
        "router_synthetic": {"accuracy": 0.9944, "macro_f1": 0.9944},
        "router_adversarial": {"accuracy": 1.0, "macro_f1": 1.0},
        "scorer": {"balanced_accuracy": 0.9062, "f1": 0.8966, "tp": 78, "tn": 96, "fp": 0, "fn": 18}
      }
    }
  ],
  "vectors": {
    "cognitive": "Problem decomposition, planning, reflection.",
    "engineering": "Code synthesis, audit, refactor, CI/CD automation.",
    "strategic": "Decision-making under uncertainty, game theory, adversarial reasoning.",
    "creative": "Narrative, world-building, divergent ideation.",
    "validation": "Truth-checking, logical consistency, output conformance."
  },
  "model_profiles": {
    "claude-opus-4-6": {"context_window_tokens": 1000000, "strengths": ["long-context", "tool use", "agentic"]},
    "gpt-5.4": {"context_window_tokens": 400000, "strengths": ["thinking", "math", "multimodal"]},
    "llama-4": {"context_window_tokens": 128000, "strengths": ["local", "open-weight"]}
  },
  "latency_classes": ["thinking", "realtime", "batch"],
  "naming_convention": "[category]-[vector]-[version].md"
}
