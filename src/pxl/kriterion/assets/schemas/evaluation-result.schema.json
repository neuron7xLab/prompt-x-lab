          "properties": {
            "phase_index": {
              "const": 0
            },
            "phase_id": {
              "const": "artifact_validation"
            },
            "previous_step_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "step_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "contract_version": {
              "type": "string"
            },
            "phase_input_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "replay_capsule": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "admitted_artifact_ids",
                "admitted_artifact_fingerprints",
                "gate_state",
                "phase_material"
              ],
              "properties": {
                "admitted_artifact_ids": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "admitted_artifact_fingerprints": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                  }
                },
                "gate_state": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string",
                    "enum": [
                      "PASS",
                      "FAIL"
                    ]
                  }
                },
                "phase_material": {
                  "type": "object",
                  "minProperties": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
