{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DomainScore",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "domain_id",
    "domain_name",
    "must_have",
    "weighted_score",
    "evidence_class_distribution",
    "domain_cap",
    "final_domain_score"
  ],
  "properties": {
    "domain_id": {
      "type": "string"
    },
    "domain_name": {
      "type": "string"
    },
    "must_have": {
      "type": "boolean"
    },
    "weighted_score": {
      "type": "number",
      "minimum": 0
    },
    "evidence_class_distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "LOW",
        "MED",
        "HIGH"
      ],
      "properties": {
        "LOW": {
          "type": "integer",
          "minimum": 0
        },
        "MED": {
          "type": "integer",
          "minimum": 0
        },
        "HIGH": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "domain_cap": {
      "type": "number",
      "minimum": 0
    },
    "final_domain_score": {
      "type": "number",
      "minimum": 0
    }
  }
}
