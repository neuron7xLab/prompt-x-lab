{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/canonical-artifact.schema.json",
  "title": "CanonicalArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "title",
    "provenance",
    "reviewer",
    "timestamps",
    "references",
    "fingerprint",
    "evidence_class",
    "domain_mapping",
    "payload"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]{3,128}$"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "RUNBOOK",
        "METRICS_SNAPSHOT",
        "PULL_REQUEST",
        "COMMIT",
        "CONFIG",
        "ARCHITECTURE_DIAGRAM",
        "INCIDENT_REPORT",
        "TEST_REPORT",
        "POLICY",
        "THREAT_MODEL",
        "PIPELINE_OUTPUT",
        "TICKET",
        "DOCUMENT"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin_actor",
        "origin_system",
        "acquisition_method",
        "source_class"
      ],
      "properties": {
        "origin_actor": {
          "type": "string",
          "minLength": 1
        },
        "origin_system": {
          "type": "string",
          "minLength": 1
        },
        "acquisition_method": {
          "type": "string",
          "enum": [
            "DIRECT_EXPORT",
            "MANUAL_CAPTURE",
            "API_RETRIEVAL",
            "REPOSITORY_CHECKOUT",
            "DERIVED_NORMALIZATION"
          ]
        },
        "source_class": {
          "type": "string",
          "enum": [
            "PRIMARY",
            "DERIVED",
            "IMPORTED"
          ]
        }
      }
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_id",
        "reviewer_independence",
        "review_status"
      ],
      "properties": {
        "reviewer_id": {
          "type": "string",
          "minLength": 1
        },
        "reviewer_independence": {
          "type": "boolean"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "NOT_REVIEWED",
            "PEER_REVIEWED",
            "INDEPENDENTLY_REVIEWED"
          ]
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "creation_time",
        "evaluation_capture_time"
      ],
      "properties": {
        "creation_time": {
          "type": "string",
          "format": "date-time"
        },
        "evaluation_capture_time": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "sha256"
      ],
      "properties": {
        "algorithm": {
          "const": "SHA-256"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "evidence_class": {
      "type": "string",
      "enum": [
        "LOW",
        "MED",
        "HIGH"
      ]
    },
    "domain_mapping": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9._:-]{2,64}$"
      }
    },
    "payload": {
      "type": "object"
    }
  }
}
