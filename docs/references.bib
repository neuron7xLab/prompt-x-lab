% prompt-x-lab — bibliographic anchors
%
% Every claim a seed module makes about its own inspiration is traced
% back to one of these entries. If a module cites an idea that is not
% in this file, it has no prior-art anchor and must either earn one or
% retract the claim.

@book{Peirce1931,
  author    = {Peirce, Charles Sanders},
  title     = {Collected Papers of Charles Sanders Peirce, Volumes 1--6},
  editor    = {Hartshorne, Charles and Weiss, Paul},
  publisher = {Harvard University Press},
  year      = {1931},
  note      = {Origin of the deduction/induction/abduction trichotomy used in the Chain-of-Thought Scaffold module.}
}

@book{Feathers2004,
  author    = {Feathers, Michael C.},
  title     = {Working Effectively with Legacy Code},
  publisher = {Prentice Hall},
  year      = {2004},
  isbn      = {978-0131177055},
  note      = {Characterization tests and the ``seam'' concept underpin the Legacy Refactor Expert module.}
}

@book{Kahneman2011,
  author    = {Kahneman, Daniel},
  title     = {Thinking, Fast and Slow},
  publisher = {Farrar, Straus and Giroux},
  year      = {2011},
  note      = {System 1/System 2 distinction informs the Executive Engine's planner/critic separation.}
}

@book{Halmos1985,
  author    = {Halmos, Paul},
  title     = {I Want to Be a Mathematician: An Automathography},
  publisher = {Springer-Verlag},
  year      = {1985},
  note      = {Halmos's teaching style --- ``the best way to learn is to do'' --- inspires the Socratic Tutor module.}
}

@article{Claessen2000,
  author  = {Claessen, Koen and Hughes, John},
  title   = {QuickCheck: A Lightweight Tool for Random Testing of Haskell Programs},
