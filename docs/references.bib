  year    = {2000},
  pages   = {268--279},
  note    = {Property-based testing methodology used in the Test Generator module.}
}

@book{Popper1959,
  author    = {Popper, Karl R.},
  title     = {The Logic of Scientific Discovery},
  publisher = {Hutchinson},
  year      = {1959},
  note      = {Falsifiability as the demarcation criterion --- load-bearing in the repo's contribution standard.}
}

@article{Wei2022CoT,
