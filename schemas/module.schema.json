{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/neuron7xLab/prompt-x-lab/schemas/module.schema.json",
  "title": "Prompt X Lab Module Frontmatter",
  "description": "JSON Schema enforced against every module's YAML frontmatter. A module that fails this schema cannot be merged.",
  "type": "object",
  "required": ["title", "category", "vector", "version", "status"],
  "additionalProperties": true,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80,
      "description": "Module title — title case, noun phrase, no emoji."
    },
    "subtitle": {
      "type": "string",
      "maxLength": 200
    },
    "category": {
      "type": "string",
      "enum": [
        "foundation",
        "cognition",
        "engineering",
        "personas",
        "validation",
        "orchestration",
        "protocols",
        "agents",
        "frameworks",
        "crypto",
        "research"
      ]
    },
    "category_label": {
      "type": "string"
    },
    "vector": {
      "type": "string",
      "enum": ["cognitive", "engineering", "strategic", "creative", "validation"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$",
      "description": "SemVer — MAJOR.MINOR.PATCH, optional pre-release."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "stable", "deprecated"]
    },
    "model_opt": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "latency": {
      "type": "string",
      "enum": ["thinking", "realtime", "batch"]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "origin": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    },
    "bytes": {
      "type": "integer",
      "minimum": 0
    },
    "lines": {
      "type": "integer",
      "minimum": 0
    },
    "validated": {
      "type": "boolean",
      "description": "True iff the module passes its evaluation spec on at least one model."
    },
    "validated_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of model IDs the module has passed its evaluation on."
    }
  }
}
