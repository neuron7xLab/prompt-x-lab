{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/neuron7xLab/prompt-x-lab/schemas/eval-spec.schema.json",
  "title": "Prompt X Lab Evaluation Spec",
  "description": "A per-module evaluation specification. Every seed module ships with exactly one spec file. The evaluation harness turns this spec into real API calls and scores the outputs with an LLM-as-judge rubric.",
  "type": "object",
  "required": ["module", "system_prompt_from", "cases", "judge"],
  "additionalProperties": false,
  "properties": {
    "module": {
      "type": "string",
      "description": "Path (from repo root) of the module under test, e.g. 02_engineering/senior-code-reviewer.md"
    },
    "system_prompt_from": {
      "type": "object",
      "required": ["file", "sections"],
      "description": "How to assemble the system prompt from the module file.",
      "properties": {
        "file": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Identity", "Core logic", "Constraints", "Output format"]
          },
          "minItems": 1
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "input", "expectations"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "kind": {
            "type": "string",
            "enum": ["positive", "adversarial", "edge"],
            "default": "positive"
          },
          "input": { "type": "string" },
          "expectations": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Checkable statements about the expected output — each becomes a rubric item."
          },
          "must_refuse": {
            "type": "boolean",
            "default": false,
            "description": "If true, the module must emit its literal REFUSED line."
          }
        }
      }
    },
    "judge": {
      "type": "object",
      "required": ["model", "rubric"],
      "properties": {
        "model": { "type": "string" },
        "rubric": {
          "type": "string",
          "enum": ["expectations-only", "expectations-with-counterfactual"]
        }
      }
    }
  }
}
